                <mxCell id="stackSlot4" value="Variable D&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;(pushed by State Z)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1.1;fontSize=13;fontColor=#222222;" parent="fsmBox" vertex="1">
