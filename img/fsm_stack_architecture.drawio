                <mxCell id="zInfo" value="Receives ref to B, C&lt;br&gt;Pushes Variable D" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#444444;" parent="stateY" vertex="1">
                    <mxGeometry x="20" y="145" width="200" height="30" as="geometry"/>
