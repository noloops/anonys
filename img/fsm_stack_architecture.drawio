                </mxCell>
                <mxCell id="yInfo" value="Receives refs to A, B from parent&lt;br&gt;Pushes Variable C on enter" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;fontColor=#444444;" parent="stateY" vertex="1">
