                <!-- Key -->
                <mxCell id="keyBox" value="&#xa;• Variables live on the stack&#xa;• Each state pushes/pops its own variables&#xa;• Access only via explicit references" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;fontSize=12;fontColor=#222222;align=left;spacingLeft=8;spacingTop=2;" parent="fsmBox" vertex="1">
