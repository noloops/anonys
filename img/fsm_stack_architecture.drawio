                <mxCell id="refAX" value="ref A" style="edgeStyle=none;html=1;strokeColor=#6c8ebf;fontColor=#6c8ebf;endArrow=open;endFill=0;dashed=1;strokeWidth=1.2;fontSize=11;" parent="fsmBox" source="stackSlot1" target="stateX" edge="1">
